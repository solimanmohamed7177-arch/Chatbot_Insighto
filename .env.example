# ─────────────────────────────────────────────────────────────────────────────
# Insighto — Environment Configuration
# Copy this to .env and fill in your real values
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key — get one FREE at https://console.groq.com
GROQ_API_KEY=YOUR_KEY_HERE

# ── Optional: Weather feature ─────────────────────────────────────────────────
# Get a free key at https://openweathermap.org/api (1000 calls/day free)
# Leave blank to disable weather — will NOT crash the app
OPENWEATHER_API_KEY=YOUR_KEY_HERE

# ── App settings ─────────────────────────────────────────────────────────────
# Max conversation turns kept in short-term memory
MAX_HISTORY=20

# Groq model to use
GROQ_MODEL=llama-3.1-8b-instant
